rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/kullanicilar/$(request.auth.uid));
    }

    // B1: Önce custom claim, yoksa kullanıcı dokümanı.
    function hasRoleClaim() {
      return request.auth != null
             && request.auth.token.rol != null
             && request.auth.token.ofisId != null;
    }

    function role() {
      return !isSignedIn() ? null
             : hasRoleClaim() ? request.auth.token.rol
             : (userDoc().data.rol != null ? userDoc().data.rol : null);
    }

    function currentOfisId() {
      return hasRoleClaim() ? request.auth.token.ofisId : userDoc().data.ofisId;
    }

    function currentMusteriId() {
      return hasRoleClaim() ? request.auth.token.musteriId : userDoc().data.musteriId;
    }

    function isStaff() {
      return role() in ['musavir', 'personel'];
    }

    function isMukellefFor(musteriId) {
      return role() == 'mukellef' && currentMusteriId() == musteriId;
    }

    // Ofis izolasyonu: dosyanın ait olduğu müşteri, personelin ofisine bağlı olmalı.
    // Claim varsa müşteri dokümanı okunur (1 okuma); yoksa kullanıcı + müşteri (2 okuma).
    function staffOfSameOffice(musteriId) {
      return isStaff()
        && firestore.get(/databases/(default)/documents/musteriler/$(musteriId)).data.ofisId
           == currentOfisId();
    }

    match /belgeler/{musteriId}/{fileName} {
      allow read:  if staffOfSameOffice(musteriId) || isMukellefFor(musteriId);
      allow write: if staffOfSameOffice(musteriId) || isMukellefFor(musteriId);
    }

    match /raporlar/{musteriId}/{fileName} {
      allow read:  if staffOfSameOffice(musteriId) || isMukellefFor(musteriId);
      allow write: if staffOfSameOffice(musteriId);
    }

    // Tanımsız tüm yollar varsayılan olarak kapalı (Firebase varsayılanı),
    // yine de açıkça belirtelim:
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

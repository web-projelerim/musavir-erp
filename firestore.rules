rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı fonksiyonlar ────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid));
    }

    // B1: Rol/ofis bilgisi önce custom claim'den okunur (Firestore okuması yok).
    // Claim henüz yoksa (geçiş dönemi / token tazelenmemiş) kullanıcı dokümanına
    // düşülür. Böylece mevcut kullanıcılar claim senkronize edilene kadar
    // çalışmaya devam eder.
    //
    // ÖNEMLİ: rol/ofisId/musteriId TEK bir bütünlük kapısına (hasRoleClaim)
    // bağlıdır. syncUserClaims her zaman rol+ofisId'yi birlikte yazar; bu yüzden
    // rol claim'i varsa ofisId claim'i de vardır. Farklı kaynaklardan (yarısı
    // claim, yarısı doküman) okuma yapılmaz — tutarsızlık önlenir.
    function hasRoleClaim() {
      return isSignedIn()
             && request.auth.token.rol != null
             && request.auth.token.ofisId != null;
    }

    function currentRole() {
      return !isSignedIn() ? null
             : hasRoleClaim() ? request.auth.token.rol
             : userDoc().data.rol;
    }

    function currentOfisId() {
      return !isSignedIn() ? null
             : hasRoleClaim() ? request.auth.token.ofisId
             : userDoc().data.ofisId;
    }

    function currentMusteriId() {
      return !isSignedIn() ? null
             : hasRoleClaim() ? request.auth.token.musteriId
             : userDoc().data.musteriId;
    }

    function isMusavir() {
      return currentRole() == 'musavir';
    }

    function isStaff() {
      // Personel rolü kaldırıldı; ofis çalışanı yalnızca müşavirdir.
      return currentRole() == 'musavir';
    }

    // Belgenin ofisId'si giriş yapmış kullanıcının ofisId'siyle eşleşiyor mu?
    function sameOffice(docOfisId) {
      return isStaff() && currentOfisId() == docOfisId;
    }

    // Yeni/güncellenen belgenin ofisId'si kullanıcının ofisId'siyle eşleşiyor mu?
    function writingToOwnOffice() {
      return isStaff() && request.resource.data.ofisId == currentOfisId();
    }

    // Mükellef kendi musteriId'li belgelere erişebilir mi?
    function isMukellefFor(musteriId) {
      return currentRole() == 'mukellef' && currentMusteriId() == musteriId;
    }

    function ownUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ─── Ofis kaydı ───────────────────────────────────────────────────────────

    match /ofisler/{docOfisId} {
      allow read:   if isSignedIn() && currentOfisId() == docOfisId;
      allow create: if isSignedIn()
                    && request.resource.data.id == docOfisId
                    && request.auth.uid == docOfisId;
      allow update: if isMusavir() && currentOfisId() == docOfisId;
      allow delete: if false;
    }

    // ─── Kullanıcılar (uid bazlı, ofisId filtresi yok) ────────────────────────

    // Davet dokümanını doğrular: yeni kullanıcının rol/ofisId/musteriId alanları
    // davetle birebir eşleşmeli, davet bekliyor durumunda ve davet e-postası
    // giriş yapan kullanıcının e-postasıyla aynı olmalı.
    // NOT (B3): email_verified şartı create anında uygulanamaz — Firebase'de yeni
    // hesabın email_verified değeri kayıt sırasında false'tur. E-posta sahiplenmesi
    // zaten davet.email == token.email eşleşmesiyle sağlanır (o e-postayla hesap
    // açılmış olmalı). Ek koruma olarak istemci, doğrulanmamış davetli kullanıcıyı
    // uygulamaya sokmaz (resolveAppUser: davetId + !emailVerified → oturum reddi).
    function davetGecerli() {
      let davet = get(/databases/$(database)/documents/davetler/$(request.resource.data.davetId)).data;
      return davet.email == request.auth.token.email
             && davet.durum == 'bekliyor'
             && davet.rol == request.resource.data.rol
             && davet.ofisId == request.resource.data.ofisId
             && (request.resource.data.rol != 'mukellef'
                 || davet.musteriId == request.resource.data.musteriId)
             // Yetkiler davetle birebir eşleşmeli — davetli kendine yetki
             // (örn. vkn_goruntule) ekleyemez. Eski/yetkisiz davetlerde her
             // iki taraf da boş listeye düşer.
             && request.resource.data.get('yetkiler', []) == davet.get('yetkiler', []);
    }

    match /kullanicilar/{userId} {
      allow read:   if isSignedIn()
                    && (ownUser(userId)
                        || (isStaff() && resource.data.ofisId == currentOfisId()));
      // İki meşru oluşturma yolu:
      //  (a) Self-bootstrap: yeni musavir kendi ofisini kurar (ofisId == uid)
      //  (b) Davetle katılım: personel/mukellef, geçerli davet dokümanıyla
      allow create: if ownUser(userId)
                    && request.resource.data.email == request.auth.token.email
                    && (
                      (request.resource.data.rol == 'musavir'
                       && request.resource.data.ofisId == request.auth.uid)
                      ||
                      (request.resource.data.davetId is string && davetGecerli())
                    );
      // Kullanıcı kendi profilini güncelleyebilir ama yetki alanlarına dokunamaz;
      // musavir yalnızca KENDİ ofisindeki kullanıcıları yönetebilir ve
      // kullanıcıyı başka ofise taşıyamaz.
      allow update: if (
                      ownUser(userId)
                      && !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['rol', 'ofisId', 'musteriId', 'yetkiler', 'aktif'])
                    ) || (
                      isMusavir()
                      && resource.data.ofisId == currentOfisId()
                      && !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['ofisId'])
                    );
      allow delete: if false;
    }

    // ─── Davetler (ofisId filtreli) ───────────────────────────────────────────

    match /davetler/{davetId} {
      allow read:   if (isStaff() && resource.data.ofisId == currentOfisId()) ||
                      (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if writingToOwnOffice() && isStaff();
      allow update: if (sameOffice(resource.data.ofisId)
                        // Ofis personeli de davetin kimlik alanlarını değiştiremez
                        && !request.resource.data.diff(resource.data).affectedKeys()
                             .hasAny(['email', 'rol', 'ofisId', 'musteriId', 'tokenHash', 'davetLinki'])) ||
                      // Davet kabul edilirken davetli yalnızca durum + usedAt yazabilir
                      (isSignedIn()
                       && resource.data.email == request.auth.token.email
                       && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['durum', 'usedAt'])
                       && request.resource.data.durum == 'kullanildi');
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Müşteriler ───────────────────────────────────────────────────────────

    match /musteriler/{musteriId} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId) && writingToOwnOffice();
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Mükellef profilleri ──────────────────────────────────────────────────

    match /mukellefiyetProfilleri/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Yükümlülükler ───────────────────────────────────────────────────────

    match /yukumlulukler/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Görevler ────────────────────────────────────────────────────────────

    match /gorevler/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Tebligatlar ─────────────────────────────────────────────────────────

    match /tebligatlar/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Beyannameler ────────────────────────────────────────────────────────

    match /beyannameler/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Raporlar ────────────────────────────────────────────────────────────

    match /raporlar/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Bildirimler ─────────────────────────────────────────────────────────

    match /bildirimler/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Tahakkuklar ─────────────────────────────────────────────────────────

    match /tahakkuklar/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Tahsilatlar ─────────────────────────────────────────────────────────

    match /tahsilatlar/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Ödemeler ────────────────────────────────────────────────────────────

    match /odemeler/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Banka ekstreleri ─────────────────────────────────────────────────────

    match /bankaEkstreleri/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Resmi gazete özetleri ────────────────────────────────────────────────

    match /resmiGazeteOzetleri/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── GİB sync logları ─────────────────────────────────────────────────────

    match /gibSyncLogs/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── KDV2 ────────────────────────────────────────────────────────────────

    match /kdv2/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Gönderimler ──────────────────────────────────────────────────────────

    match /gonderimler/{id} {
      // Mükellef kendisine ait gönderim kayıtlarını (panel bildirimleri dahil) okuyabilir.
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Belgeler ────────────────────────────────────────────────────────────

    match /belgeler/{id} {
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      allow create: if writingToOwnOffice() ||
                      (isMukellefFor(request.resource.data.musteriId) &&
                       request.resource.data.ofisId == currentOfisId());
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isStaff() && sameOffice(resource.data.ofisId);
    }

    match /belgeTalepleri/{id} {
      // Müşavir/personel kendi ofisindeki talepleri; mükellef kendine ait
      // talepleri görebilir.
      allow read:   if sameOffice(resource.data.ofisId) ||
                      isMukellefFor(resource.data.musteriId);
      // Talebi yalnızca ofis personeli oluşturur (mükellepten belge ister)
      allow create: if writingToOwnOffice();
      // Personel talebi günceller; mükellef yalnızca durumu 'yuklendi'ye
      // çekebilir ve karşılayan belgeId'yi bağlayabilir (talebi kapatamaz).
      allow update: if sameOffice(resource.data.ofisId) ||
                      (isMukellefFor(resource.data.musteriId) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['durum', 'belgeId', 'guncellenmeTarihi']) &&
                       request.resource.data.durum == 'yuklendi');
      allow delete: if isStaff() && sameOffice(resource.data.ofisId);
    }

    // ─── Audit logları ────────────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read:   if isMusavir() && sameOffice(resource.data.ofisId);
      allow create: if isSignedIn()
                    && request.resource.data.actorId == request.auth.uid
                    && request.resource.data.createdAt is string
                    && (isStaff()
                        ? request.resource.data.ofisId == currentOfisId()
                        : true);
      allow update, delete: if false;
    }

    // ─── Entegrasyon ayarları ─────────────────────────────────────────────────

    match /gibEntegrasyonAyarlari/{id} {
      allow read:   if isMusavir() && sameOffice(resource.data.ofisId);
      allow create: if isMusavir() && writingToOwnOffice();
      allow update: if isMusavir() && sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /lucaEntegrasyonAyarlari/{id} {
      allow read:   if isStaff() && sameOffice(resource.data.ofisId);
      allow create: if isMusavir() && writingToOwnOffice();
      allow update: if isMusavir() && sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /whatsappEntegrasyonAyarlari/{id} {
      allow read:   if isStaff() && sameOffice(resource.data.ofisId);
      allow create: if isMusavir() && writingToOwnOffice();
      allow update: if isMusavir() && sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /bankaEntegrasyonAyarlari/{id} {
      allow read:   if isStaff() && sameOffice(resource.data.ofisId);
      allow create: if isMusavir() && writingToOwnOffice();
      allow update: if isMusavir() && sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /emailEntegrasyonAyarlari/{id} {
      allow read:   if isStaff() && sameOffice(resource.data.ofisId);
      allow create: if isMusavir() && writingToOwnOffice();
      allow update: if isMusavir() && sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /entegrasyonLoglari/{id} {
      allow read:   if isMusavir() && sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if isMusavir() && sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── GİB oturum cache (server-only, client okuyamaz) ─────────────────────

    match /gibSessions/{ofisId} {
      allow read, write: if false; // sadece Admin SDK erişir
    }

    // ─── GİB entegrasyon ayarları (şifreli) — sadece musavir ─────────────────
    // Not: gibEntegrasyonAyarlari şifreli secret blob içerir.
    // Yukarıda isMusavir() kontrolü zaten var; burada ek kural gerekmez.

    // ─── Hızlı notlar ────────────────────────────────────────────────────────

    match /notlar/{notId} {
      allow read:   if isSignedIn()
                    && (resource.data.createdBy == request.auth.uid
                        || request.auth.token.email in resource.data.paylasilanEmails
                        || sameOffice(resource.data.ofisId));
      allow create: if isStaff() && writingToOwnOffice();
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.createdBy == request.auth.uid
                        || request.auth.token.email in resource.data.paylasilanEmails)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["tikleyenler"]);
    }

    // ─── GİB Sözleşmeleri ────────────────────────────────────────────────────

    match /gibSozlesmeleri/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Vergi Takvimi ───────────────────────────────────────────────────────

    match /vergiTakvimi/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /vergiTakvimiGuncellemeleri/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    // ─── Beyanname Takip (hücre matrisi + notlar) ─────────────────────────────

    match /beyanTakipHucreleri/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if isMusavir() && sameOffice(resource.data.ofisId);
    }

    match /beyanTakipNotlari/{id} {
      allow read:   if sameOffice(resource.data.ofisId);
      allow create: if writingToOwnOffice();
      allow update: if sameOffice(resource.data.ofisId);
      allow delete: if sameOffice(resource.data.ofisId);
    }

  }
}
